{
  "name": "ai-telegram-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ai-telegram-bridge": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test": "npm run typecheck && npm run check && vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "grammy": "^1.42.0",
    "telegramify-markdown": "^1.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
